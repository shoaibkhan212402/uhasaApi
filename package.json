{
  "name": "uasa-training-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-assets.mjs && tsx watch src/index.ts",
    "build": "npx tsc && node scripts/copy-assets.mjs",
    "render-build": "npm install && npx tsc && node scripts/copy-assets.mjs",
    "sync-logos": "node scripts/copy-assets.mjs",
    "setup-db": "node dist/db/init.js && node dist/db/migrate.js",
    "start": "node index.js",
    "postinstall": "npx tsc && node scripts/copy-assets.mjs",
    "db:init": "tsx src/db/init.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:ensure-lms": "tsx src/scripts/ensureLmsTables.ts",
    "db:ensure-elearner": "tsx src/db/ensureElearnerSchema.ts",
    "db:ensure-elearner:prod": "node dist/db/ensureElearnerSchema.js",
    "db:seed": "tsx src/db/seed.ts",
    "db:init:prod": "node dist/db/init.js",
    "db:migrate:prod": "node dist/db/migrate.js",
    "db:seed:prod": "node dist/db/seed.js",
    "db:seed-workshops": "tsx src/db/seed-workshops.ts",
    "send-reminders": "tsx src/scripts/sendReminders.ts",
    "hash-password": "tsx src/scripts/hashPassword.ts",
    "test:connections": "tsx src/scripts/testConnections.ts",
    "test:invoice-samples": "tsx src/scripts/testInvoiceSamples.ts",
    "import-approve-orders": "tsx src/scripts/importApproveOrders.ts",
    "import-approve-orders:dry-run": "tsx src/scripts/importApproveOrders.ts --dry-run",
    "import-order-exports": "tsx src/scripts/importOrderExports.ts --all",
    "import-order-exports:dry-run": "tsx src/scripts/importOrderExports.ts --all --dry-run",
    "import-invoices-excel": "tsx src/scripts/importInvoicesExcel.ts",
    "import-invoices-excel:dry-run": "tsx src/scripts/importInvoicesExcel.ts --dry-run",
    "import-corporate-users": "tsx src/scripts/importCorporateUsers.ts",
    "import-corporate-users:dry-run": "tsx src/scripts/importCorporateUsers.ts --dry-run",
    "import-corporate-participants": "tsx src/scripts/importCorporateParticipants.ts",
    "import-corporate-participants:dry-run": "tsx src/scripts/importCorporateParticipants.ts --dry-run",
    "import-bank-users": "tsx src/scripts/importBankUsers.ts",
    "import-bank-users:dry-run": "tsx src/scripts/importBankUsers.ts --dry-run",
    "import-individual-registrations": "tsx src/scripts/importIndividualRegistrations.ts --no-fulfill",
    "import-individual-registrations:fulfill": "tsx src/scripts/importIndividualRegistrations.ts",
    "import-individual-registrations:dry-run": "tsx src/scripts/importIndividualRegistrations.ts --dry-run --export-sql",
    "import-individual-registrations:sql": "tsx src/scripts/importIndividualRegistrations.ts --export-sql --dry-run",
    "import-bank-participants": "tsx src/scripts/importBankParticipants.ts",
    "import-bank-participants:dry-run": "tsx src/scripts/importBankParticipants.ts --dry-run"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.4",
    "@types/nodemailer": "^6.4.16",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.19.1",
    "basic-ftp": "^5.0.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.11.3",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.17.2",
    "typescript": "^5.5.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {}
}
