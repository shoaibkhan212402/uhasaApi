# Server
PORT=3001
NODE_ENV=production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
# Comma-separated frontend URLs allowed to call the API (ignored when CORS_ALLOW_ALL is not false)
CORS_ORIGIN=https://uhasha.vercel.app,https://uasatraining.ahwuae.com,http://localhost:5173
# Set to false to restrict to CORS_ORIGIN + defaults only
CORS_ALLOW_ALL=true

# MySQL (Hostinger)
# Remote dev: use srvXXX.hstgr.io + whitelist your IP in hPanel → Databases → Remote MySQL
# On-server deploy: use DB_HOST=localhost
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name

# FTP (Hostinger)
# Remote dev: port 21 may be blocked by ISP/firewall — test with FileZilla first
# On-server deploy: consider local file path instead of FTP, or use localhost FTP
FTP_HOST=ftp.yourdomain.com
FTP_PORT=21
FTP_USER=your_ftp_user
FTP_PASSWORD=your_ftp_password
FTP_SECURE=false
# Usually: /public_html/your-folder (check File Manager in hPanel)
FTP_BASE_PATH=/public_html/uasatrainingftp
FTP_PUBLIC_URL=https://yourdomain.com/uasatrainingftp

# SMTP (optional — emails log to console in dev without SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=UASA Training
SMTP_FROM_EMAIL=info@uasatraining.com

# Certificate logo URLs (optional — defaults to /api/certificate-assets on this server)
# CERTIFICATE_ASSETS_BASE_URL=https://your-api-domain.com/api/certificate-assets
# API_PUBLIC_URL=https://your-api-domain.com/api/certificate-assets

# Default admin (created on db init)
ADMIN_EMAIL=admin@uasatraining.com
ADMIN_PASSWORD=Admin@123

# Public URLs (required for Telr payment return redirects)
FRONTEND_URL=https://uasatraining.ahwuae.com
API_PUBLIC_URL=https://trainingapi.ahwuae.com

# Telr payment gateway (https://telr.com)
TELR_STORE_ID=
TELR_AUTH_KEY=
# Optional — defaults to TELR_AUTH_KEY for webhook signature verification
# TELR_WEBHOOK_SECRET=
# Set to 1 for test mode, 0 for live payments
TELR_TEST_MODE=1
# Configure in Telr Merchant Admin → Transaction advice:
# https://trainingapi.ahwuae.com/api/payments/telr/webhook
